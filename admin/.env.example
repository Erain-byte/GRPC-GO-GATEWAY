# 服务器配置
SERVER_PORT=8081
SERVER_MODE=debug

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_NAME=admin_db

# Redis 配置
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=24h

# gRPC 服务地址
GRPC_AI_SERVICE=localhost:50052
GRPC_USER_SERVICE=localhost:50051

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
